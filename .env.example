# =============================================================================
# Frontend (Vite) — used in browser via import.meta.env
# =============================================================================

# Contact Form API endpoint (set by Amplify from CDK output, or manually for local dev)
VITE_CONTACT_API_URL=https://your-api-id.execute-api.us-west-2.amazonaws.com/contact

# CloudFront CDN base URL for media assets (videos, thumbnails, images)
VITE_CDN_BASE_URL=https://d2fc83sck42gx7.cloudfront.net

# Cloudflare Turnstile site key (get from Cloudflare Dashboard -> Turnstile -> your widget)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key-here

# =============================================================================
# Lambda (server-side) — set in CDK stack, used at runtime in Lambda
# =============================================================================

# Email address that receives contact form submissions (must be SES-verified)
CONTACT_EMAIL=your-verified-email@example.com

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://stealinglight.hk,https://www.stealinglight.hk

# Cloudflare Turnstile secret key (server-side verification)
TURNSTILE_SECRET=your-turnstile-secret-key-here

# =============================================================================
# CDK Deployment — used when running cdk deploy
# =============================================================================

# AWS account and region for CDK deployment
CDK_DEFAULT_ACCOUNT=your-aws-account-id
CDK_DEFAULT_REGION=us-west-2
